# Path to the backend checkout that owns the current Django schema and Docker Compose file.
BACKEND_REPO=../archetype-clean/backend

# Prefer explicit URLs for real trial/staging/production runs.
LEGACY_DATABASE_URL=postgresql://postgres:password@postgres:5432/legacy_source
TARGET_DATABASE_URL=postgresql://postgres:password@postgres:5432/target_current

# Same-server convenience mode. Used only when LEGACY_DATABASE_URL is not set.
LEGACY_DATABASE_NAME=legacy_source
TARGET_DATABASE_NAME=target_current

# Optional Docker binary override. Useful on systems where Docker Desktop is not on PATH.
# DOCKER_BIN=/Applications/Docker.app/Contents/Resources/bin/docker
