  %% ----------------------------
  subgraph ANNOTATIONS["Annotations (new DB)"]
    direction LR
    annotations_graph["annotations_graph"]
    annotations_graph_positions["annotations_graph_positions"]
    annotations_graphcomponent["annotations_graphcomponent"]
    annotations_graphcomponent_features["annotations_graphcomponent_features"]
  end

  %% ----------------------------
  %% CONTEXT (referenced families)
  %% ----------------------------
  subgraph CONTEXT["Referenced outside Annotations"]
    direction LR
    symbols_structure_allograph["symbols_structure_allograph"]
    symbols_structure_position["symbols_structure_position"]
    symbols_structure_component["symbols_structure_component"]
    symbols_structure_feature["symbols_structure_feature"]
    scribes_hand["scribes_hand"]
    manuscripts_itemimage["manuscripts_itemimage"]
