  %% ----------------------------
  %% FK edges (as per CSV)
  %% ----------------------------

  %% annotations_graph.*
  annotations_graph -- "allograph_id → id" --> symbols_structure_allograph
  annotations_graph -- "hand_id → id" --> scribes_hand
  annotations_graph -- "item_image_id → id" --> manuscripts_itemimage

  %% annotations_graph_positions.*
  annotations_graph_positions -- "graph_id → id" --> annotations_graph
  annotations_graph_positions -- "position_id → id" --> symbols_structure_position

  %% annotations_graphcomponent.*
  annotations_graphcomponent -- "graph_id → id" --> annotations_graph
  annotations_graphcomponent -- "component_id → id" --> symbols_structure_component

  %% annotations_graphcomponent_features.*
  annotations_graphcomponent_features -- "graphcomponent_id → id" --> annotations_graphcomponent
  annotations_graphcomponent_features -- "feature_id → id" --> symbols_structure_feature
